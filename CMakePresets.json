{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux",
      "binaryDir": "${sourceDir}/build/linux",
      "generator": "Ninja",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "windows",
      "binaryDir": "${sourceDir}/build/windows",
      "generator": "Visual Studio 17 2022",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "macos",
      "binaryDir": "${sourceDir}/build/macos",
      "generator": "Ninja",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo", "RECREATION_FETCH_SDL3": "ON" },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "android",
      "binaryDir": "${sourceDir}/build/android",
      "generator": "Ninja",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-29",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "RECREATION_BUILD_TOOLS": "OFF"
      }
    }
  ]
}
