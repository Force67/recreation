<?xml version="1.0" encoding="utf-8"?>
<!-- Where to find the Recreation.Scripting SDK package. Point <local> at the
     folder holding the .nupkg the engine ships (or that you produced with
     `dotnet pack -c Release sdk/Recreation.Scripting.csproj`). Drop the nupkg in
     ./packages next to this file, or change the path. -->
<configuration>
  <packageSources>
    <add key="local" value="./packages" />
  </packageSources>
</configuration>
